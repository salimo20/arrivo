# ---------- NTA: server-side only ----------
NTA_API_KEY=replace_with_your_primary_or_secondary_key
NTA_TRIP_UPDATES_URL=https://api.nationaltransport.ie/gtfsr/v2/TripUpdates
NTA_API_HEADER=x-api-key
GTFS_STATIC_URL=https://www.transportforireland.ie/transitData/Data/GTFS_Realtime.zip

# ---------- Browser authentication ----------
# Windows PowerShell generation command is in DEPLOYMENT.md.
APP_SESSION_SECRET=replace_with_a_long_random_secret_at_least_32_characters
SESSION_TTL_MINUTES=30
TURNSTILE_SECRET_KEY=replace_with_cloudflare_turnstile_secret
VITE_TURNSTILE_SITE_KEY=replace_with_cloudflare_turnstile_site_key

# Build-time operator filter. The default build already selects Dublin Bus.
# Clear this only if you later want to include every operator in the NTA feed.
ALLOWED_AGENCY_NAMES=Bus Átha Cliath

# Local/demo settings. AUTH_MODE=off is blocked on deployed Netlify contexts.
AUTH_MODE=turnstile
DEMO_MODE=false
VITE_DEMO_MODE=false
